{
  "manifest_version": 3,
  "name": "Browse Code Bridge",
  "version": "2.0",
  "description": "Autonomous AI Code Execution Bridge",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.chatgpt.com/*",
        "*://gemini.google.com/*",
        "*://*.claude.ai/*",
        "*://*.claudemcpcontent.com/*",
        "*://*.huggingface.co/*"
      ],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["spoof.js"],
      "matches": ["<all_urls>"]
    }
  ]
}